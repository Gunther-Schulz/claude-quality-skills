#!/usr/bin/env bash
set -euo pipefail

# Recursion guard: claude -p triggers UserPromptSubmit hooks too
if [ "${CLAUDE_SKILL_CLASSIFYING:-}" = "1" ]; then
    exit 0
fi
export CLAUDE_SKILL_CLASSIFYING=1

# Paths: env vars > XDG spec > defaults
CONFIGDIR="${CLAUDE_SKILLS_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/claude-skills}"
STATEDIR="${CLAUDE_SKILLS_STATE:-${XDG_STATE_HOME:-$HOME/.local/state}/claude-skills}"
CONFIGFILE="${CONFIGDIR}/config.sh"
LOG_FILE="${STATEDIR}/classifier.log"

# --- Defaults (overridden by config.sh) ---
CLASSIFIER_MODEL="claude-haiku-4-5-20251001"
CLASSIFIER_EFFORT="low"
CLASSIFIER_MAX_BUDGET=""

# Source user config
[ -f "$CONFIGFILE" ] && source "$CONFIGFILE"

# Ensure state dir exists
mkdir -p "$STATEDIR"

INPUT=$(cat)

# Extract user prompt from hook JSON
PROMPT=$(echo "$INPUT" | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    print(data.get('prompt', ''))
except:
    pass
" 2>/dev/null)

if [ -z "$PROMPT" ]; then
    echo "$(date -Is) | NO_INPUT" >> "$LOG_FILE"
    exit 0
fi

# Build claude -p arguments
CLAUDE_ARGS=(--model "$CLASSIFIER_MODEL" --effort "$CLASSIFIER_EFFORT" --output-format json)
[ -n "$CLASSIFIER_MAX_BUDGET" ] && CLAUDE_ARGS+=(--max-budget-usd "$CLASSIFIER_MAX_BUDGET")

# Classify using claude CLI
RAW=$(echo "$PROMPT" | claude -p "${CLAUDE_ARGS[@]}" "Classify this message. Output ONLY the text after the arrow. Nothing else. If none match, output nothing.

code task → Run /code-quality before writing code.
investigation/debug task → Run /critical-thinking before proceeding.
proposal/design evaluation → Run /critical-evaluation before responding." 2>/dev/null || true)

# Parse result, cost, and duration from JSON
eval "$(echo "$RAW" | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    result = data.get('result', '').strip()
    cost = data.get('total_cost_usd', 0)
    duration_api = data.get('duration_api_ms', 0)
    duration_total = data.get('duration_ms', 0)
    tokens_in = data.get('usage', {}).get('input_tokens', 0)
    tokens_out = data.get('usage', {}).get('output_tokens', 0)
    print(f'RESULT={repr(result)}')
    print(f'COST={cost:.6f}')
    print(f'API_MS={duration_api}')
    print(f'TOTAL_MS={duration_total}')
    print(f'TOKENS_IN={tokens_in}')
    print(f'TOKENS_OUT={tokens_out}')
except:
    print('RESULT=\"\"')
    print('COST=0')
    print('API_MS=0')
    print('TOTAL_MS=0')
    print('TOKENS_IN=0')
    print('TOKENS_OUT=0')
" 2>/dev/null)"

# Log with cost and duration
echo "$(date -Is) | ${RESULT:-NO_MATCH} | \$${COST} ${API_MS}ms/${TOTAL_MS}ms ${TOKENS_IN}in+${TOKENS_OUT}out | ${PROMPT:0:80}" >> "$LOG_FILE"

# Output result — plain stdout gets injected as system-reminder
if [ -n "$RESULT" ]; then
    echo "$RESULT"
fi

exit 0
